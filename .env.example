# Site URL (used for sitemap, canonical, OG tags)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Hero 3D robot: r3f (default) | spline
NEXT_PUBLIC_HERO_ROBOT=r3f

# Optional — floating companion GLB (omit to use built-in procedural robot)
# NEXT_PUBLIC_COMPANION_MODEL_URL=/models/companion.glb

# Option A — Spline scene URL (export from Spline → Deploy → copy .splinecode link)
NEXT_PUBLIC_SPLINE_SCENE_URL=https://prod.spline.design/your-scene/scene.splinecode

# Optional: enhances JD matcher pitch via Groq (server-side only)
GROQ_API_KEY=
